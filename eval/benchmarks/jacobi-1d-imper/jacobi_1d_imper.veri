// Integer Jacobi-1D benchmark in Veritas.
fn main() -> int {
    let mut a: [int; 128] = [0; 128];
    let mut b: [int; 128] = [0; 128];

    for i in 0..128 {
        a[i] = (i + 2) / 128;
        b[i] = (i + 3) / 128;
    }

    for t in 0..80 {
        for i in 1..127 {
            b[i] = (a[i - 1] + a[i] + a[i + 1]) / 3;
        }
        for j in 1..127 {
            a[j] = b[j];
        }
    }

    let mut sum: int = 0;
    for i in 0..128 {
        sum = sum + a[i];
    }

    print_int(sum);
    print_char(10);
    sum
}
